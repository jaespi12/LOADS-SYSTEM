{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "grouped-case.schema.json",
  "title": "Grouped Case",
  "type": "object",
  "required": ["id", "name", "members"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "members": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    }
  },
  "additionalProperties": false
}
