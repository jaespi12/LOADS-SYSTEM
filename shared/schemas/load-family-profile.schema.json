{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "load-family-profile.schema.json",
  "title": "Load Family Profile",
  "type": "object",
  "required": ["families"],
  "properties": {
    "families": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["familyId", "status", "sourceType"],
        "properties": {
          "familyId": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["DRAFT", "IN_REVIEW", "APPROVED", "SUPERSEDED"] },
          "sourceType": { "type": "string", "enum": ["MANUAL", "REFERENCE", "GENERATED"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
