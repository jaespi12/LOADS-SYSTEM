{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kinematics-profile.schema.json",
  "title": "Kinematics Profile",
  "type": "object",
  "required": ["profileId", "source", "revision", "entries"],
  "properties": {
    "profileId": { "type": "string", "minLength": 1 },
    "source": { "type": "string", "minLength": 1 },
    "revision": { "type": "string", "minLength": 1 },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["station", "speed", "cantDeficiency"],
        "properties": {
          "station": { "type": "number" },
          "speed": { "type": "number" },
          "cantDeficiency": { "type": "number" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
