{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "train-section.schema.json",
  "title": "Train Profile",
  "type": "object",
  "required": ["trainId", "trainName", "sections"],
  "properties": {
    "trainId": { "type": "string", "minLength": 1 },
    "trainName": { "type": "string", "minLength": 1 },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "length", "axles"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "length": { "type": "number" },
          "axles": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["offset", "load"],
              "properties": {
                "offset": { "type": "number" },
                "load": { "type": "number" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
